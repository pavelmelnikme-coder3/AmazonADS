# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql://adsflow:your_strong_password_here@localhost:5432/adsflow

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_minimum_32_characters_here

# AES-256 key for token encryption: 32 random bytes in hex
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_string_here

# ─── Amazon LwA (Login with Amazon) ──────────────────────────────────────────
# 1. Go to: https://developer.amazon.com/apps-and-games/console/app/list
# 2. Create Security Profile
# 3. Under "Web Settings" add Allowed Return URLs: http://localhost:3000/connect/amazon/callback
# 4. Copy Client ID and Client Secret below
AMAZON_CLIENT_ID=amzn1.application-oa2-client.XXXXXXXXXXXX
AMAZON_CLIENT_SECRET=your_client_secret_here

# Callback URL must match exactly what you set in LwA Security Profile
AMAZON_REDIRECT_URI=http://localhost:3000/connect/amazon/callback

# Amazon Ads API base URLs (do not change unless using different region)
AMAZON_ADS_API_URL=https://advertising-api.amazon.com       # NA
AMAZON_ADS_API_EU_URL=https://advertising-api-eu.amazon.com # EU
AMAZON_ADS_API_FE_URL=https://advertising-api-fe.amazon.com # FE

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── AI (Anthropic Claude) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your_key_here
# Optional: override model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Sync settings ───────────────────────────────────────────────────────────
ENTITY_SYNC_INTERVAL_HOURS=2
REPORT_SYNC_HOUR_UTC=6

# ─── Amazon SP-API (Seller Central) ──────────────────────────────────────────
# Separate app from Ads API. Create at: https://sellercentral.amazon.com/apps/develop
# Required role: "Amazon Catalog" read access
SP_API_CLIENT_ID=amzn1.application-oa2-client.XXXX
SP_API_CLIENT_SECRET=your_sp_api_secret
# Refresh token from SP-API app authorization (per seller)
# User gets this after authorizing your SP-API app in Seller Central
SP_API_REFRESH_TOKEN=Atzr|...

# SP-API base URLs by region
SP_API_URL_NA=https://sellingpartnerapi-na.amazon.com
SP_API_URL_EU=https://sellingpartnerapi-eu.amazon.com
SP_API_URL_FE=https://sellingpartnerapi-fe.amazon.com
